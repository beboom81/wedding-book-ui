# Base URL of the C# API (Azure Web App). No trailing path needed.
VITE_API_URL=http://localhost:5080/

# Public guest access key for this invitation (from the dashboard).
# Leave empty to disable the comment feature on the guest page.
VITE_GUEST_KEY=

# Wedding date/time for the countdown (YYYY-MM-DD HH:mm:ss, local).
VITE_WEDDING_TIME=2024-01-01 09:30:00

# Background music (path under /assets or a full URL). Empty to disable.
VITE_AUDIO=/assets/music/pure-love-304010.mp3

# Confetti on open (only used when comments are disabled).
VITE_CONFETTI=true

# Build base path for GitHub Pages project sites, e.g. /wedding-book-ui/
VITE_BASE=/
